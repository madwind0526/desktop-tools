{
  "name": "desktop-tools",
  "version": "1.0.0",
  "description": "Desktop Tools — 계산기, 환율, 도량형, D-day, 음력, 알람",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "express": "^4.18.2",
    "korean-lunar-calendar": "^0.3.6",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.desktop-tools.app",
    "productName": "Desktop Tools",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
